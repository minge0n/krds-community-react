{
  "name": "krds-community-react",
  "version": "0.1.0",
  "description": "KRDS (Korea Design System) React component library built on Base UI",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "DESIGN.md"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "tsup",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "storybook:build": "storybook build"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
    "@biomejs/biome": "^2.4.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/react-vite": "^10.3.6",
    "@storybook/test": "^8.6.15",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "krds-react": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^10.3.6",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "krds",
    "korea-design-system",
    "react",
    "base-ui",
    "accessibility",
    "government",
    "design-system"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mingeon/new-krds-react"
  }
}
